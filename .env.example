# ============================================================
# ZeroArsenal 环境变量示例
# 复制本文件为 .env 后按需修改。所有变量均为可选（有默认值）。
# 至少配置一个 LLM API Key 才能正常生成叙事。
# ============================================================

# ── LLM 提供商密钥 ─────────────────────────────────────────
# 也可在前端「设置 → LLM 配置」中填写并热保存，无需重启。
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx

# ── 服务监听 ───────────────────────────────────────────────
# 后端 HTTP/SSE 监听地址与端口。
HOST=0.0.0.0
PORT=8001

# ── 数据库 ─────────────────────────────────────────────────
# SQLite 路径（相对 backend/ 目录）。无需手动建表，首次启动自动迁移。
DB_PATH=data/zero_arsenal.db

# ── 运行环境 ───────────────────────────────────────────────
# development / production。development 默认开启 Skill 热重载。
ENVIRONMENT=development

# ── 事件总线（多进程部署时启用 Redis）──────────────────────
# 不设置时使用单进程内存总线（单实例够用）。
# 多 worker / 多实例时必须设置 Redis，否则 SSE 事件无法跨进程广播。
# REDIS_URL=redis://localhost:6379/0

# ── 鉴权（可选）────────────────────────────────────────────
# 设置后所有 API 需携带 Authorization: Bearer <token>。留空则不鉴权。
# ZERO_ARSENAL_API_TOKEN=

# ── 限流（可选）────────────────────────────────────────────
# 本地开发默认关闭（0）；生产部署可按需设为 1 开启。
# 每分钟请求数 / 突发桶容量 / 总开关（0 关闭，1 开启）。
ZERO_ARSENAL_RATE_ENABLED=0
ZERO_ARSENAL_RATE_LIMIT=60
ZERO_ARSENAL_RATE_BURST=10

# ── 提示词审计（调试用）────────────────────────────────────
# 设为 1 时记录每次提示词组装详情，便于排查注入内容。
ZERO_ARSENAL_PROMPT_AUDIT=0
# 自定义审计日志目录（默认 backend/data/audit）。
# ZERO_ARSENAL_AUDIT_DIR=

# ── 提示词模板目录覆盖（可选）──────────────────────────────
# 指向自定义模板目录，覆盖内置 prompts/templates。
# PROMPT_TEMPLATES_DIR=

# ── Skill 热重载（开发用）──────────────────────────────────
# 强制开启/关闭文风 Skill 文件的热重载（默认随 ENVIRONMENT 判定）。
# ZERO_ARSENAL_HOT_RELOAD=1
# ZERO_ARSENAL_NO_HOT_RELOAD=1

# ── 扩展搜索路径覆盖（可选）────────────────────────────────
# 追加额外扩展目录，分号分隔。优先级高于内置/用户/项目目录。
# ZERO_ARSENAL_EXTENSIONS_OVERRIDE=E:\my-exts;D:\shared-exts
